generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  fullName     String
  username     String    @unique
  passwordHash String
  role         String    @default("clerk") // admin, clerk, accountant
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  invoices     Invoice[] @relation("IssuedBy")
  auditLogs    AuditLog[]
}

model Subscriber {
  id               String    @id @default(cuid())
  subscriberNumber String    @unique
  subscriberName   String
  meterNumber      String    @unique
  routeNumber      String
  cabinName        String
  locationName     String    @default("")
  phone            String    @default("")
  status           String    @default("active") // active, inactive
  notes            String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  invoices         Invoice[]
}

model Invoice {
  id               String   @id @default(cuid())
  invoiceNumber    String   @unique
  subscriberId     String
  subscriber       Subscriber @relation(fields: [subscriberId], references: [id])
  periodFrom       String
  periodTo         String
  previousReading  Float
  currentReading   Float
  consumptionKwh   Float
  unitPrice        Float
  baseValue        Float
  servicesAmount   Float    @default(0)
  arrearsAmount    Float    @default(0)
  paidDuringPeriod Float    @default(0)
  grossAmount      Float
  netDue           Float
  netDueWords      String
  currency         String   @default("ريال")
  status           String   @default("draft") // draft, issued, cancelled
  pdfPath          String?
  notes            String   @default("")
  issuedById       String?
  issuedBy         User?    @relation("IssuedBy", fields: [issuedById], references: [id])
  issuedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([subscriberId, periodFrom, periodTo])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  entityType  String
  entityId    String
  action      String
  oldValues   String?  // JSON
  newValues   String?  // JSON
  createdAt   DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
